# Supabase (free): https://supabase.com → New project → SQL Editor → run supabase/schema.sql
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Project Settings → API → service_role key (server only, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Password for /admin/comments
ADMIN_PASSWORD="choose-a-strong-password"

# Story submissions via Resend (free): https://resend.com
RESEND_API_KEY=re_xxxxxxxx
SUBMISSION_TO_EMAIL=aniket.mangalampalli@gmail.com
RESEND_FROM_EMAIL="Beyond the Medal <onboarding@resend.dev>"
